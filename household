<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#080812">
<title>HomeKeeper</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#080812;--card:rgba(15,15,30,0.75);--border:rgba(255,255,255,0.08);--text:#e0e0e0;--text2:rgba(255,255,255,0.5);--text3:rgba(255,255,255,0.3);--cyan:#0ff;--magenta:#f0f;--lime:#0f0;--amber:#fb0;--red:#f55;--input-bg:rgba(255,255,255,0.06);--input-border:rgba(255,255,255,0.1)}
html,body{height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:linear-gradient(180deg,#080812 0%,#0a0a1a 50%,#0d0815 100%);color:var(--text);-webkit-tap-highlight-color:transparent}
#app{max-width:480px;margin:0 auto;height:100%;display:flex;flex-direction:column;position:relative;overflow:hidden}
canvas#lasers{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;opacity:0.35;z-index:0}
.header{padding:12px 20px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:20;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);background:rgba(8,8,18,0.85)}
.header.emp{border-bottom:1px solid rgba(255,0,255,0.15)}.header.worker{border-bottom:1px solid rgba(0,255,255,0.15)}
.header-icon{width:36px;height:36px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px}
.header h1{font-size:16px;font-weight:800;color:#fff}.header p{font-size:11px}
.switch-btn{margin-left:auto;font-size:11px;color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.05);border:none;padding:4px 8px;border-radius:8px;cursor:pointer}
.content{flex:1;overflow-y:auto;padding:20px 16px 100px;position:relative;z-index:10;-webkit-overflow-scrolling:touch}.content::-webkit-scrollbar{display:none}
.tab-bar{position:fixed;bottom:0;left:0;right:0;max-width:480px;margin:0 auto;z-index:20;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);background:rgba(8,8,18,0.92);display:flex;justify-content:space-around;padding:8px 0;padding-bottom:max(8px,env(safe-area-inset-bottom))}
.tab-btn{display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 6px;border-radius:12px;border:none;background:none;cursor:pointer;position:relative;transition:all 0.2s}
.tab-btn svg{width:17px;height:17px;stroke-width:1.5}.tab-btn.active svg{stroke-width:2.5}
.tab-btn span{font-size:9px;font-weight:600}
.tab-badge{position:absolute;top:-2px;right:-2px;width:16px;height:16px;border-radius:50%;background:#f00;color:#fff;font-size:9px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 8px rgba(255,0,0,0.5)}
.card{border-radius:16px;padding:20px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);background:var(--card);border:1px solid var(--border);margin-bottom:16px}
.card.gc{border-color:rgba(0,255,255,0.2);box-shadow:0 0 20px rgba(0,255,255,0.08)}
.card.gm{border-color:rgba(255,0,255,0.2);box-shadow:0 0 20px rgba(255,0,255,0.08)}
.card.gl{border-color:rgba(0,255,0,0.15);box-shadow:0 0 20px rgba(0,255,0,0.06)}
.label{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;font-weight:700;margin-bottom:12px}
.label.cyan{color:rgba(0,255,255,0.6)}.label.mag{color:rgba(255,0,255,0.6)}.label.amb{color:rgba(255,180,0,0.6)}.label.lim{color:rgba(0,255,0,0.6)}.label.red{color:rgba(255,80,80,0.6)}
input,textarea,select{width:100%;padding:10px 12px;border-radius:12px;font-size:14px;background:var(--input-bg);border:1px solid var(--input-border);color:var(--text);outline:none;font-family:inherit;-webkit-appearance:none}
input:focus,textarea:focus{border-color:rgba(0,255,255,0.3)}input[type="date"],input[type="time"]{color-scheme:dark}textarea{resize:none}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 20px;border-radius:12px;font-size:13px;font-weight:700;border:1px solid;cursor:pointer;transition:all 0.2s;font-family:inherit}
.btn.full{width:100%}.btn.sm{padding:6px 12px;font-size:11px}
.btn.cyan{background:rgba(0,255,255,0.12);color:var(--cyan);border-color:rgba(0,255,255,0.3);box-shadow:0 0 12px rgba(0,255,255,0.15)}
.btn.mag{background:rgba(255,0,255,0.12);color:var(--magenta);border-color:rgba(255,0,255,0.3);box-shadow:0 0 12px rgba(255,0,255,0.15)}
.btn.red{background:rgba(255,0,0,0.12);color:var(--red);border-color:rgba(255,0,0,0.3)}
.btn.amb{background:rgba(255,180,0,0.12);color:var(--amber);border-color:rgba(255,180,0,0.3)}
.btn.ghost{background:rgba(255,255,255,0.04);color:var(--text2);border-color:rgba(255,255,255,0.08)}
.btn:disabled{opacity:0.3;pointer-events:none}
.row{display:flex;gap:8px;align-items:center}.row.between{justify-content:space-between}.row.wrap{flex-wrap:wrap}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.grid7{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.area-btn{padding:12px;border-radius:12px;text-align:left;border:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.03);cursor:pointer;transition:all 0.3s}
.area-btn.sel{background:rgba(0,255,255,0.1);border-color:rgba(0,255,255,0.4);box-shadow:0 0 15px rgba(0,255,255,0.15)}
.area-btn .icon{font-size:20px;margin-bottom:4px}.area-btn .name{font-size:11px;font-weight:700;color:#fff}.area-btn .count{font-size:10px;color:var(--text3)}
.progress-wrap{margin-bottom:8px}
.progress-label{display:flex;justify-content:space-between;font-size:10px;margin-bottom:4px}
.progress-bar{width:100%;height:8px;border-radius:8px;background:rgba(255,255,255,0.08);overflow:hidden}
.progress-fill{height:100%;border-radius:8px;transition:width 0.5s}
.chore-item{display:flex;align-items:center;gap:8px;padding:10px;border-radius:12px;margin-bottom:6px;transition:all 0.2s;flex-wrap:wrap}
.chore-item.done{background:rgba(0,255,0,0.06);border:1px solid rgba(0,255,0,0.15)}
.chore-item.undone{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.04)}
.chore-item.nn{border-left:3px solid var(--red)}
.chk{width:20px;height:20px;border-radius:6px;border:2px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all 0.2s}
.chk.checked{background:var(--lime);border-color:var(--lime);box-shadow:0 0 8px rgba(0,255,0,0.4)}
.chore-name{font-size:13px;flex:1;min-width:0}.chore-name.done-t{text-decoration:line-through;color:var(--text3)}
.chore-time{font-size:10px;color:rgba(0,255,255,0.5);cursor:pointer;display:flex;align-items:center;gap:3px;white-space:nowrap}
.time-edit{display:flex;align-items:center;gap:4px}.time-edit input{width:56px;padding:3px;text-align:center;font-size:11px;border-radius:6px}
.time-edit button{background:none;border:none;cursor:pointer;padding:2px}
.nn-tag{font-size:8px;padding:1px 6px;border-radius:6px;background:rgba(255,80,80,0.15);color:var(--red);font-weight:700;text-transform:uppercase;letter-spacing:0.5px}
.deadline-tag{font-size:8px;padding:1px 6px;border-radius:6px;background:rgba(255,180,0,0.15);color:var(--amber);font-weight:600}
.status-badge{font-size:10px;padding:2px 8px;border-radius:99px;font-weight:600}
.badge-pending{background:rgba(255,180,0,0.15);color:var(--amber)}
.badge-approved,.badge-acknowledged{background:rgba(0,255,0,0.15);color:var(--lime)}
.badge-declined{background:rgba(255,0,0,0.15);color:var(--red)}
.stat-box{text-align:center;padding:12px;border-radius:12px}
.stat-box .val{font-size:22px;font-weight:900}.stat-box .lbl{font-size:10px;color:var(--text2);margin-top:2px}
.cal-day{aspect-ratio:1;border-radius:10px;font-size:11px;font-weight:600;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;cursor:pointer;transition:all 0.2s;border:1px solid transparent}
.cal-day.worked{background:rgba(0,255,0,0.2);border-color:rgba(0,255,0,0.4);color:var(--lime)}.cal-day.leave{background:rgba(255,180,0,0.1);border-color:rgba(255,180,0,0.3);color:var(--amber)}
.cal-day.today{box-shadow:0 0 10px rgba(255,0,255,0.4)}.cal-day.normal{background:rgba(255,255,255,0.03);color:var(--text2)}
.cal-hdr{text-align:center;font-size:10px;color:var(--text3);font-weight:600;padding:4px 0}
.upload-zone{display:flex;align-items:center;justify-content:center;gap:8px;padding:16px;border:2px dashed rgba(0,255,255,0.2);border-radius:12px;cursor:pointer;transition:all 0.2s;font-size:13px;color:var(--text2)}
.photo-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.photo-thumb{position:relative;border-radius:12px;overflow:hidden;border:1px solid rgba(0,255,255,0.15)}
.photo-thumb img{width:100%;height:120px;object-fit:cover;display:block}
.photo-thumb .date{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.7);font-size:10px;padding:4px 6px;color:rgba(255,255,255,0.6)}
.photo-thumb .del{position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(255,0,0,0.8);color:#fff;border:none;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.leave-type-btn{flex:1;padding:8px;border-radius:12px;font-size:11px;font-weight:700;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);color:var(--text2);cursor:pointer;text-align:center;transition:all 0.2s}
.leave-type-btn.sel{background:rgba(255,0,255,0.2);border-color:rgba(255,0,255,0.4);color:var(--magenta)}
.log-entry{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;font-size:11px;margin-bottom:4px}
.log-entry.in{background:rgba(0,255,0,0.04)}.log-entry.out{background:rgba(255,255,255,0.02)}
.notif{position:fixed;top:16px;left:16px;right:16px;max-width:448px;margin:0 auto;z-index:100;padding:12px;border-radius:12px;background:rgba(0,255,255,0.15);border:1px solid rgba(0,255,255,0.3);color:var(--cyan);backdrop-filter:blur(10px);font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 0 20px rgba(0,255,255,0.2);animation:slideIn 0.3s ease}
@keyframes slideIn{from{transform:translateY(-20px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
.glow{text-shadow:0 0 8px currentColor}
.note-block{padding:10px 12px;border-radius:10px;background:rgba(0,255,255,0.04);border:1px solid rgba(0,255,255,0.1);margin-bottom:8px;font-size:12px;color:var(--text);line-height:1.5;position:relative}
.note-block .note-label{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:rgba(0,255,255,0.4);font-weight:700;margin-bottom:4px}
.note-block.rule{background:rgba(255,180,0,0.04);border-color:rgba(255,180,0,0.15)}.note-block.rule .note-label{color:rgba(255,180,0,0.5)}
.emp-pill{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);cursor:pointer;transition:all 0.2s;font-size:12px;color:var(--text)}
.emp-pill.active{border-color:rgba(0,255,255,0.4);background:rgba(0,255,255,0.1);color:#fff}
.emp-pill .dot{width:8px;height:8px;border-radius:50%}
.hidden{display:none!important}
.login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;position:relative}
.login-wrap{width:100%;max-width:380px;position:relative;z-index:10}
.login-title{text-align:center;margin-bottom:32px}
.login-title .emoji{font-size:48px;filter:drop-shadow(0 0 20px rgba(0,255,255,0.5));margin-bottom:8px}
.login-title h1{font-size:28px;font-weight:900;color:#fff;text-shadow:0 0 30px rgba(0,255,255,0.5)}
.login-title p{font-size:12px;color:rgba(0,255,255,0.6);margin-top:6px}
.login-card{padding:20px;border-radius:16px;margin-bottom:12px;transition:all 0.3s;backdrop-filter:blur(8px)}
.login-card.employee{background:rgba(0,255,255,0.05);border:1px solid rgba(0,255,255,0.2);cursor:pointer}
.login-card.employer{background:var(--card);border:1px solid rgba(255,0,255,0.2)}
.login-card .icon-wrap{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center}
.login-card h3{font-size:16px;font-weight:800;color:#fff}.login-card .sub{font-size:11px;color:var(--text3)}
.pin-row{display:flex;gap:8px;margin-top:12px}.pin-row input{flex:1}
.pin-error{font-size:11px;color:var(--red);margin-top:8px}
.flex1{flex:1}.tc{text-align:center}.tw{color:#fff}.mb8{margin-bottom:8px}.mb12{margin-bottom:12px}
.emp-select-card{padding:14px;border-radius:14px;border:1px solid rgba(0,255,255,0.15);background:rgba(0,255,255,0.04);margin-bottom:8px;cursor:pointer;transition:all 0.2s}
.emp-select-card:active{transform:scale(0.98)}
.emp-select-card .ename{font-size:14px;font-weight:700;color:#fff}.emp-select-card .epin{font-size:10px;color:var(--text3)}
</style>
</head>
<body>
<canvas id="lasers"></canvas>
<div id="app">
  <div id="login-screen" class="login-screen">
    <div class="login-wrap">
      <div class="login-title"><div class="emoji">&#127968;</div><h1>HomeKeeper</h1><p>Household Management System</p></div>
      <div id="login-content"></div>
    </div>
  </div>
  <div id="main-app" style="display:none;flex-direction:column;height:100%">
    <div id="header" class="header worker">
      <div id="header-icon" class="header-icon" style="background:rgba(0,255,255,0.15)">&#127968;</div>
      <div><h1>HomeKeeper</h1><p id="header-sub" style="color:rgba(0,255,255,0.5)">Employee</p></div>
      <button class="switch-btn" onclick="logout()">&#8617; Switch</button>
    </div>
    <div id="content" class="content"></div>
    <div id="tab-bar" class="tab-bar"></div>
  </div>
</div>
<div id="notif-container"></div>
<script>
// ========== DATA ==========
const AREAS={
  kitchen:{name:"Kitchen",icon:"\u{1F373}",chores:[{name:"Wash dishes",minutes:30},{name:"Clean countertops",minutes:15},{name:"Mop floor",minutes:20},{name:"Clean appliances",minutes:25},{name:"Empty bins",minutes:10},{name:"Clean oven",minutes:40}]},
  lounge:{name:"Living Room",icon:"\u{1F6CB}",chores:[{name:"Vacuum carpet",minutes:25},{name:"Dust surfaces",minutes:20},{name:"Clean windows",minutes:30},{name:"Tidy cushions & throws",minutes:10},{name:"Polish furniture",minutes:20}]},
  bedrooms:{name:"Bedrooms",icon:"\u{1F6CF}",chores:[{name:"Change bed linen",minutes:20},{name:"Make beds",minutes:10},{name:"Vacuum floors",minutes:20},{name:"Dust furniture",minutes:15},{name:"Organize closets",minutes:30}]},
  bathrooms:{name:"Bathrooms",icon:"\u{1F6BF}",chores:[{name:"Scrub toilet",minutes:15},{name:"Clean shower/bath",minutes:25},{name:"Clean basin & mirror",minutes:15},{name:"Mop floor",minutes:15},{name:"Restock supplies",minutes:5}]},
  laundry:{name:"Laundry",icon:"\u{1F455}",chores:[{name:"Sort & load washing",minutes:15},{name:"Hang clothes to dry",minutes:20},{name:"Iron clothes",minutes:60},{name:"Fold & store clothes",minutes:30}]},
  outdoor:{name:"Outdoor Areas",icon:"\u{1F33F}",chores:[{name:"Sweep patio/stoep",minutes:20},{name:"Water plants",minutes:15},{name:"Clean braai area",minutes:25},{name:"Wipe outdoor furniture",minutes:15}]},
  garage:{name:"Garage",icon:"\u{1F697}",chores:[{name:"Sweep floor",minutes:20},{name:"Organize shelves",minutes:30},{name:"Dust & wipe surfaces",minutes:15}]}
};

const DEFAULTS={
  employerPin:"1234",employerEmail:"",
  employees:[{id:1,name:"Employee 1",pin:"0001",color:"#0ff",monthlySalary:4500,workHoursPerDay:7,breakMinutes:30,workDaysPerWeek:5,signedIn:false,signInTime:null,signOutTime:null,selectedAreas:[],chores:[],completedChores:[],breakages:[],photos:[],calendarDays:{},leaveRequests:[],clockLog:[]}],
  areaNotes:{},areaRules:{},choreFlags:{},choreDeadlines:{}
};

let S={};
function load(){try{const d=localStorage.getItem('hk3');S=d?{...DEFAULTS,...JSON.parse(d)}:{...DEFAULTS};if(!S.employees||!S.employees.length)S.employees=[DEFAULTS.employees[0]];if(!S.areaNotes)S.areaNotes={};if(!S.areaRules)S.areaRules={};if(!S.choreFlags)S.choreFlags={};if(!S.choreDeadlines)S.choreDeadlines={}}catch(e){S={...DEFAULTS}}}
function save(){try{localStorage.setItem('hk3',JSON.stringify(S))}catch(e){}}
load();

let role=null,currentTab='home',selMonth=new Date().toISOString().slice(0,7),activeEmpId=null,loginStep='choose';

function E(){return S.employees.find(e=>e.id===activeEmpId)||S.employees[0]}
function fmt(d){return d?new Date(d).toLocaleTimeString("en-ZA",{hour:"2-digit",minute:"2-digit"}):"--:--"}
function today(){return new Date().toISOString().slice(0,10)}
function dateDisp(d){return new Date(d+"T00:00:00").toLocaleDateString("en-ZA",{weekday:"short",day:"numeric",month:"short"})}
function eff(e){return(e||E()).workHoursPerDay*60-(e||E()).breakMinutes}
function alloc(e){return(e||E()).chores.reduce((t,c)=>t+c.minutes,0)}
function comp(e){const em=e||E();return em.completedChores.reduce((t,id)=>{const c=em.chores.find(x=>x.id===id);return t+(c?c.minutes:0)},0)}
function dRate(e){const em=e||E();return Math.round((em.monthlySalary/(em.workDaysPerWeek*4.33))*100)/100}
function calcSal(ms,e){const em=e||E();const[y,m]=ms.split("-").map(Number);const days=new Date(y,m,0).getDate();let dw=0;for(let d=1;d<=days;d++){const k=`${y}-${String(m).padStart(2,"0")}-${String(d).padStart(2,"0")}`;if(em.calendarDays[k]?.worked)dw++}return{daysWorked:dw,salary:Math.round(dw*dRate(em)*100)/100}}
function notify(msg){const el=document.createElement('div');el.className='notif';el.innerHTML=msg;document.getElementById('notif-container').appendChild(el);setTimeout(()=>el.remove(),3000)}
function progressHTML(v,mx,lbl,col){const p=Math.min((v/mx)*100,100);const c=p>90?'#f00':p>70?'#ff0':col||'#0ff';return`<div class="progress-wrap"><div class="progress-label"><span style="color:var(--text2)">${lbl}</span><span style="color:${c}">${v}/${mx} min</span></div><div class="progress-bar"><div class="progress-fill" style="width:${p}%;background:${c};box-shadow:0 0 10px ${c}80"></div></div></div>`}
function choreKey(area,name){return area+'::'+name}
function isNN(area,name){return S.choreFlags[choreKey(area,name)]==='nn'}
function getDeadline(area,name){return S.choreDeadlines[choreKey(area,name)]||null}

// ========== LASER BG ==========
(function(){const cv=document.getElementById('lasers'),ctx=cv.getContext('2d');function rs(){cv.width=innerWidth;cv.height=innerHeight}rs();addEventListener('resize',rs);const B=Array.from({length:8},()=>({x:Math.random()*cv.width,y:Math.random()*cv.height,vx:(Math.random()-.5)*2,vy:(Math.random()-.5)*2,hue:Math.random()*360,len:120+Math.random()*200}));(function d(){ctx.fillStyle="rgba(8,8,18,0.15)";ctx.fillRect(0,0,cv.width,cv.height);B.forEach(b=>{b.x+=b.vx;b.y+=b.vy;b.hue=(b.hue+.5)%360;if(b.x<0||b.x>cv.width)b.vx*=-1;if(b.y<0||b.y>cv.height)b.vy*=-1;const a=Math.atan2(b.vy,b.vx),g=ctx.createLinearGradient(b.x,b.y,b.x+Math.cos(a)*b.len,b.y+Math.sin(a)*b.len);g.addColorStop(0,`hsla(${b.hue},100%,70%,0.8)`);g.addColorStop(1,`hsla(${b.hue},100%,50%,0)`);ctx.strokeStyle=g;ctx.lineWidth=1.5;ctx.shadowBlur=12;ctx.shadowColor=`hsla(${b.hue},100%,60%,0.6)`;ctx.beginPath();ctx.moveTo(b.x,b.y);ctx.lineTo(b.x+Math.cos(a)*b.len,b.y+Math.sin(a)*b.len);ctx.stroke();ctx.shadowBlur=0});requestAnimationFrame(d)})()})();

// ========== LOGIN ==========
function renderLogin(){
  const el=document.getElementById('login-content');
  if(loginStep==='choose'){
    let h=`<div class="login-card employee" onclick="loginStep='emp_select';renderLogin()"><div class="row" style="gap:16px"><div class="icon-wrap" style="background:rgba(0,255,255,0.15)"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0ff" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div><div><h3>Employee</h3><p class="sub">Sign in, manage chores, request leave</p></div></div></div>`;
