    const note=S.areaNotes[k],rules=S.areaRules[k];
    const nnChores=a.chores.filter(c=>isNN(k,c.name));
    const dlChores=a.chores.filter(c=>getDeadline(k,c.name));
    if(!note&&!rules&&!nnChores.length&&!dlChores.length)return;
    h+=`<div class="card"><h3 class="tw" style="font-size:14px;font-weight:700;margin-bottom:10px">${a.icon} ${a.name}</h3>`;
    if(note)h+=`<div class="note-block"><div class="note-label">&#128205; Placement Notes</div>${note.replace(/\n/g,'<br>')}</div>`;
    if(rules)h+=`<div class="note-block rule"><div class="note-label">&#9888; Rules & Needs</div>${rules.replace(/\n/g,'<br>')}</div>`;
    if(nnChores.length){h+=`<div style="margin-top:8px"><div style="font-size:10px;color:var(--red);font-weight:700;text-transform:uppercase;margin-bottom:6px">&#128308; Non-Negotiable Chores</div>`;nnChores.forEach(c=>{const dl=getDeadline(k,c.name);h+=`<div style="padding:6px 10px;border-radius:8px;background:rgba(255,80,80,0.06);border:1px solid rgba(255,80,80,0.12);margin-bottom:4px;font-size:12px;color:var(--text);display:flex;align-items:center;gap:8px"><span class="nn-tag">Must-do</span><span class="flex1">${c.name}</span>${dl?`<span class="deadline-tag">by ${dl}</span>`:''}<span style="color:var(--text3);font-size:10px">${c.minutes}m</span></div>`});h+=`</div>`}
    h+=`</div>`;
  });
  if(h.split('class="card"').length<=2)h+=`<div class="card"><p class="tc" style="color:var(--text3);font-size:12px;padding:20px">No house guide notes have been added yet. Your employer can add placement notes, rules, and mark non-negotiable chores.</p></div>`;
  return h;
}

function vBreak(){
  const em=E();
  let h=`<div class="card"><div class="label amb">Log a Breakage</div><input id="brk-text" placeholder="Describe what was broken..." style="margin-bottom:10px"><label class="upload-zone" style="margin-bottom:10px;border-color:rgba(255,180,0,0.2)">&#128247; Attach Photo<input type="file" accept="image/*" multiple style="display:none" onchange="handleWorkPhoto(this)"></label><button class="btn amb full" onclick="addBreakage()">&#9888; Log Breakage</button></div>`;
  if(em.breakages.length){h+=`<div class="card"><div class="label amb">Reports</div>`;em.breakages.slice().reverse().forEach(b=>{h+=`<div style="padding:12px;border-radius:12px;background:rgba(255,180,0,0.05);border:1px solid rgba(255,180,0,0.15);margin-bottom:8px"><div class="row between"><span class="tw" style="font-size:13px;font-weight:600">${b.text}</span><span class="status-badge badge-${b.status}">${b.status}</span></div><p style="font-size:10px;color:var(--text3);margin-top:4px">${b.date}</p></div>`});h+=`</div>`}
  return h;
}

function vLeave(){
  let h=`<div class="card gm"><div class="label mag">Request Leave / Report Sick</div><div class="row" style="margin-bottom:10px">`;
  [['sick','&#129298; Sick'],['leave','&#127958; Leave'],['family','&#128104;&#8205;&#128105;&#8205;&#128103; Family']].forEach(([t,l])=>{h+=`<div class="leave-type-btn${t==='sick'?' sel':''}" data-type="${t}" onclick="selectLeaveType('${t}')">${l}</div>`});
  h+=`</div><div style="margin-bottom:8px"><label style="font-size:10px;color:var(--text2)">Date</label><input type="date" id="leave-date" value="${today()}"></div><div style="margin-bottom:10px"><label style="font-size:10px;color:var(--text2)">Note</label><textarea id="leave-note" rows="2" placeholder="Details..."></textarea></div><button class="btn mag full" onclick="submitLeave()">&#10084; Submit</button></div>`;
  const reqs=E().leaveRequests;
  if(reqs.length){h+=`<div class="card"><div class="label mag">Your Requests</div>`;reqs.slice().reverse().forEach(l=>{const ico=l.type==='sick'?'&#129298;':l.type==='leave'?'&#127958;':'&#128104;&#8205;&#128105;&#8205;&#128103;';h+=`<div style="padding:10px;border-radius:12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);margin-bottom:6px" class="row between"><div><span class="tw" style="font-size:13px;font-weight:600">${ico} ${dateDisp(l.date)}</span>${l.note?`<p style="font-size:10px;color:var(--text3);margin-top:2px">${l.note}</p>`:''}</div><span class="status-badge badge-${l.status}">${l.status}</span></div>`});h+=`</div>`}
  return h;
}

function vSalary(){
  const em=E(),sal=calcSal(selMonth);
  const[y,m]=selMonth.split("-").map(Number);const mn=new Date(y,m-1).toLocaleDateString("en-ZA",{month:"long",year:"numeric"});
  return`<div class="card gl"><div class="tc" style="margin-bottom:16px"><div style="font-size:32px;color:#0f0;filter:drop-shadow(0 0 10px rgba(0,255,0,0.5))">&#128176;</div><h3 class="tw" style="font-size:20px;font-weight:900;margin-top:8px">Pay Summary</h3></div><div class="row between" style="margin-bottom:16px"><button class="btn sm cyan" onclick="changeMonth(-1)">&#9664;</button><span style="color:#0ff;font-weight:700">${mn}</span><button class="btn sm cyan" onclick="changeMonth(1)">&#9654;</button></div><div style="font-size:13px"><div class="row between" style="padding:10px;border-radius:12px;background:rgba(255,255,255,0.03);margin-bottom:6px"><span style="color:var(--text2)">Daily Rate</span><span style="color:#0ff;font-weight:700">R${dRate().toFixed(2)}</span></div><div class="row between" style="padding:10px;border-radius:12px;background:rgba(255,255,255,0.03);margin-bottom:6px"><span style="color:var(--text2)">Days Worked</span><span class="tw" style="font-weight:700">${sal.daysWorked}</span></div><div class="row between" style="padding:12px;border-radius:12px;background:rgba(0,255,0,0.08);border:1px solid rgba(0,255,0,0.2)"><span style="color:#0f0;font-weight:600">Earned</span><span style="color:#0f0;font-weight:900;font-size:20px;text-shadow:0 0 10px rgba(0,255,0,0.4)">R${sal.salary.toFixed(2)}</span></div></div></div>`;
}

function vPhotos(){
  let h=`<div class="card"><div class="label cyan">Work Photos</div><label class="upload-zone">&#128247; Upload<input type="file" accept="image/*" multiple style="display:none" onchange="handleWorkPhoto(this)"></label></div>`;
  const em=E();if(em.photos.length){h+=`<div class="card"><div class="photo-grid">`;em.photos.forEach(p=>{h+=`<div class="photo-thumb"><img src="${p.src}"><div class="date">${p.date}</div><button class="del" onclick="delPhoto(${p.id})">&#10005;</button></div>`});h+=`</div></div>`}
  return h;
}

// ========== EMPLOYER VIEWS ==========
function empSelector(){
  let h=`<div class="row wrap" style="margin-bottom:16px">`;
  S.employees.forEach(em=>{h+=`<div class="emp-pill${em.id===activeEmpId?' active':''}" onclick="selectActiveEmp(${em.id})"><div class="dot" style="background:${em.color}"></div>${em.name}</div>`});
  h+=`</div>`;return h;
}

function vDash(){
  const em=E(),sal=calcSal(selMonth,em);
  const pL=em.leaveRequests.filter(l=>l.status==='pending').length,pB=em.breakages.filter(b=>b.status==='pending').length;
  let h=`<div class="card gm"><div class="row" style="gap:12px"><div style="width:40px;height:40px;border-radius:12px;background:rgba(255,0,255,0.15);display:flex;align-items:center;justify-content:center">${IC.shield.replace('currentColor','#f0f')}</div><div><h2 class="tw" style="font-size:18px;font-weight:800">Employer Dashboard</h2><p style="font-size:11px;color:var(--text2)">Manage your team</p></div></div></div>`;
  h+=empSelector();
  h+=`<div class="grid2">`;
  [{v:`R${em.monthlySalary}`,l:'Monthly Salary',c:'#0f0'},{v:sal.daysWorked,l:'Days This Month',c:'#0ff'},{v:pL,l:'Pending Leave',c:'#fb0'},{v:pB,l:'Breakages',c:'#f55'}].forEach(s=>{h+=`<div class="card"><div class="stat-box"><div class="val" style="color:${s.c};text-shadow:0 0 12px ${s.c}60">${s.v}</div><div class="lbl">${s.l}</div></div></div>`});
  h+=`</div>`;
  if(em.signedIn)h+=`<div class="card gl"><div class="row" style="padding:8px;border-radius:12px;background:rgba(0,255,0,0.06);gap:8px"><div style="width:10px;height:10px;border-radius:50%;background:#0f0;box-shadow:0 0 10px #0f0"></div><span style="font-size:13px;color:#0f0;font-weight:600">${em.name} is signed in since ${fmt(em.signInTime)}</span></div></div>`;
  // Recent breakages
  const pendingB=em.breakages.filter(b=>b.status==='pending');
  if(pendingB.length){h+=`<div class="card"><div class="label amb">Pending Breakages</div>`;pendingB.forEach(b=>{h+=`<div style="padding:10px;border-radius:12px;background:rgba(255,180,0,0.05);border:1px solid rgba(255,180,0,0.15);margin-bottom:8px"><div class="row between"><span class="tw" style="font-size:12px;font-weight:600">${b.text}</span><button class="btn sm cyan" onclick="ackBreakage(${b.id})">&#10003;</button></div><p style="font-size:10px;color:var(--text3);margin-top:4px">${b.date}</p></div>`});h+=`</div>`}
  return h;
}

function vEmployees(){
  let h=`<div class="card gm"><div class="row between"><div class="label mag" style="margin-bottom:0">Team Members (${S.employees.length}/4)</div><button class="btn sm mag" onclick="addEmployee()" ${S.employees.length>=4?'disabled':''}>+ Add</button></div></div>`;
  S.employees.forEach(em=>{
    h+=`<div class="card" style="border-left:3px solid ${em.color}"><div class="row between" style="margin-bottom:12px"><h3 class="tw" style="font-size:15px;font-weight:700">${em.name}</h3><button class="btn sm red" onclick="if(confirm('Remove ${em.name}?'))removeEmployee(${em.id})">Remove</button></div>`;
    [{k:'name',l:'Name',t:'text'},{k:'pin',l:'PIN',t:'text'},{k:'monthlySalary',l:'Monthly Salary (R)',t:'number'},{k:'workHoursPerDay',l:'Hours/Day',t:'number'},{k:'breakMinutes',l:'Break (min)',t:'number'},{k:'workDaysPerWeek',l:'Days/Week',t:'number'}].forEach(f=>{
      h+=`<div style="margin-bottom:8px"><label style="font-size:10px;color:var(--text2)">${f.l}</label><input type="${f.t}" value="${em[f.k]}" onchange="saveEmpField(${em.id},'${f.k}',this.value,${f.t==='number'})"></div>`;
    });
    h+=`<p style="font-size:10px;color:var(--text3)">Daily rate: R${dRate(em).toFixed(2)}</p></div>`;
  });
  h+=`<div class="card"><div class="label mag">Employer Security</div><div style="margin-bottom:8px"><label style="font-size:10px;color:var(--text2)">Employer PIN</label><input value="${S.employerPin}" onchange="S.employerPin=this.value;save()"></div><div><label style="font-size:10px;color:var(--text2)">Alert Email</label><input type="email" value="${S.employerEmail}" onchange="S.employerEmail=this.value;save()"></div></div>`;
  return h;
}

function vGuideEdit(){
  let h=`<div class="card gm"><div class="tc"><div style="font-size:32px;margin-bottom:8px">&#128221;</div><h3 class="tw" style="font-size:18px">House Guide Editor</h3><p style="font-size:11px;color:var(--text2);margin-top:4px">Set placement notes, rules, non-negotiables & deadlines per area</p></div></div>`;
  Object.entries(AREAS).forEach(([k,a])=>{
    h+=`<div class="card"><h3 class="tw" style="font-size:14px;font-weight:700;margin-bottom:12px">${a.icon} ${a.name}</h3>`;
    // Placement notes
    h+=`<div style="margin-bottom:12px"><div class="label cyan" style="margin-bottom:6px">&#128205; Placement Notes</div><textarea id="note-${k}" rows="3" placeholder="e.g. Remote controls go on the coffee table. Cushions arranged left to right: grey, white, grey...">${S.areaNotes[k]||''}</textarea><button class="btn sm cyan" onclick="saveAreaNote('${k}')" style="margin-top:6px">Save Note</button></div>`;
    // Rules
    h+=`<div style="margin-bottom:12px"><div class="label amb" style="margin-bottom:6px">&#9888; Rules & Needs</div><textarea id="rule-${k}" rows="3" placeholder="e.g. Never use bleach on marble counters. Always unplug appliances after use...">${S.areaRules[k]||''}</textarea><button class="btn sm amb" onclick="saveAreaRule('${k}')" style="margin-top:6px">Save Rules</button></div>`;
    // Chores with NN toggle and deadline
    h+=`<div class="label red" style="margin-bottom:8px">Chore Settings</div>`;
    a.chores.forEach(c=>{
      const ck=choreKey(k,c.name),nn=S.choreFlags[ck]==='nn',dl=S.choreDeadlines[ck]||'';
      const safeId=k+'-'+c.name.replace(/\s/g,'_');
      h+=`<div style="padding:8px 10px;border-radius:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05);margin-bottom:6px${nn?';border-left:3px solid var(--red)':''}"><div class="row between" style="margin-bottom:4px"><span style="font-size:12px;color:var(--text)">${c.name} <span style="color:var(--text3);font-size:10px">(${c.minutes}m)</span></span><button class="btn sm ${nn?'red':'ghost'}" onclick="toggleNN('${k}','${c.name}')">${nn?'&#128308; Must-Do':'Set Must-Do'}</button></div><div class="row" style="gap:6px"><span style="font-size:10px;color:var(--text3);white-space:nowrap">Complete by:</span><input type="time" id="dl-${safeId}" value="${dl}" style="flex:1;padding:4px 8px;font-size:11px" onchange="saveDeadline('${k}','${c.name}')"></div></div>`;
    });
    h+=`</div>`;
  });
  return h;
}

function vCal(){
  const em=E(),[y,m]=selMonth.split("-").map(Number);const dIM=new Date(y,m,0).getDate(),fD=new Date(y,m-1,1).getDay();
  const mn=new Date(y,m-1).toLocaleDateString("en-ZA",{month:"long",year:"numeric"});
  let h=empSelector();
  h+=`<div class="card"><div class="row between" style="margin-bottom:16px"><button class="btn sm mag" onclick="changeMonth(-1)">&#9664;</button><span style="color:#f0f;font-weight:700">${mn}</span><button class="btn sm mag" onclick="changeMonth(1)">&#9654;</button></div><div class="grid7">`;
  ['S','M','T','W','T','F','S'].forEach(d=>{h+=`<div class="cal-hdr">${d}</div>`});
  for(let i=0;i<fD;i++)h+=`<div></div>`;
  for(let d=1;d<=dIM;d++){const k=`${y}-${String(m).padStart(2,"0")}-${String(d).padStart(2,"0")}`;const w=em.calendarDays[k]?.worked,isT=k===today(),lv=em.leaveRequests.find(l=>l.date===k&&l.status==='approved');
    h+=`<div class="cal-day${w?' worked':lv?' leave':' normal'}${isT?' today':''}" onclick="toggleWorkDay('${k}')">${d}${w?'<div style="width:4px;height:4px;border-radius:50%;background:#0f0"></div>':''}</div>`}
  h+=`</div><p class="tc" style="font-size:10px;color:var(--text3);margin-top:12px">Tap to toggle days</p></div>`;
  const sal=calcSal(selMonth,em);
  h+=`<div class="card"><div class="grid2"><div class="stat-box" style="background:rgba(0,255,0,0.06);border:1px solid rgba(0,255,0,0.15);border-radius:12px"><div class="val" style="color:#0f0">${sal.daysWorked}</div><div class="lbl">Days</div></div><div class="stat-box" style="background:rgba(255,0,255,0.06);border:1px solid rgba(255,0,255,0.15);border-radius:12px"><div class="val" style="color:#f0f">R${sal.salary.toFixed(2)}</div><div class="lbl">Owed</div></div></div></div>`;
  return h;
}

function vClockLog(){
  let h=empSelector();
  const em=E();h+=`<div class="card"><div class="label mag">Clock Log</div>`;
  if(!em.clockLog.length)h+=`<p class="tc" style="color:var(--text3);font-size:11px;padding:32px">No entries.</p>`;
  else em.clockLog.slice().reverse().forEach(c=>{h+=`<div class="log-entry ${c.type}" style="border:1px solid ${c.type==='in'?'rgba(0,255,0,0.1)':'rgba(255,255,255,0.04)'}"><span style="color:${c.type==='in'?'#0f0':'var(--text3)'};font-weight:600">${c.type==='in'?'&#10148; In':'&#10094; Out'}</span><span class="flex1"></span><span style="color:var(--text3)">${c.date} ${fmt(c.time)}</span></div>`});
  h+=`</div>`;return h;
}

function vEmpLeave(){
  let h=empSelector();const em=E();
  h+=`<div class="card"><div class="label mag">Leave Requests</div>`;
  if(!em.leaveRequests.length)h+=`<p class="tc" style="color:var(--text3);font-size:11px;padding:32px">No requests.</p>`;
  else em.leaveRequests.slice().reverse().forEach(l=>{
    const ico=l.type==='sick'?'&#129298; Sick':l.type==='leave'?'&#127958; Leave':'&#128104;&#8205;&#128105;&#8205;&#128103; Family';
    h+=`<div style="padding:12px;border-radius:12px;background:${l.status==='pending'?'rgba(255,180,0,0.05)':l.status==='approved'?'rgba(0,255,0,0.04)':'rgba(255,0,0,0.04)'};border:1px solid ${l.status==='pending'?'rgba(255,180,0,0.2)':l.status==='approved'?'rgba(0,255,0,0.15)':'rgba(255,0,0,0.15)'};margin-bottom:8px"><div class="row between"><div><span class="tw" style="font-size:13px;font-weight:600">${ico}</span><p style="font-size:11px;color:var(--text2);margin-top:2px">${dateDisp(l.date)}</p>${l.note?`<p style="font-size:10px;color:var(--text3);margin-top:2px">${l.note}</p>`:''}</div><span class="status-badge badge-${l.status}">${l.status}</span></div>`;
    if(l.status==='pending')h+=`<div class="row" style="margin-top:10px;gap:8px"><button class="btn cyan sm" onclick="approveLeave(${l.id})">&#10003; Approve</button><button class="btn red sm" onclick="declineLeave(${l.id})">&#10005; Decline</button></div>`;
    h+=`</div>`});
  h+=`</div>`;return h;
}

// ========== INIT ==========
if(!activeEmpId&&S.employees.length)activeEmpId=S.employees[0].id;
renderLogin();
</script>
