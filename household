  let h=`<div class="card">${progressHTML(alloc(),eff(),'Time ('+eff()+' min)')}</div>`;
  em.selectedAreas.forEach(ak=>{
    const area=AREAS[ak],ac=em.chores.filter(c=>c.area===ak);
