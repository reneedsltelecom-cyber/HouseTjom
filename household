    h+=`<div class="card"><h3 class="tw" style="font-size:14px;font-weight:700;margin-bottom:8px">${area.icon} ${area.name}</h3>`;
    if(note)h+=`<div class="note-block"><div class="note-label">&#128205; Placement Notes</div>${note.replace(/\n/g,'<br>')}</div>`;
    if(rules)h+=`<div class="note-block rule"><div class="note-label">&#9888; House Rules</div>${rules.replace(/\n/g,'<br>')}</div>`;
    // Non-negotiables first
    const sorted=[...ac].sort((a,b)=>(isNN(ak,b.name)?1:0)-(isNN(ak,a.name)?1:0));
    sorted.forEach(ch=>{
      const done=em.completedChores.includes(ch.id),nn=isNN(ak,ch.name),dl=getDeadline(ak,ch.name);
      h+=`<div class="chore-item ${done?'done':'undone'}${nn?' nn':''}"><div class="chk${done?' checked':''}" onclick="toggleChore('${ch.id}')">${done?'&#10003;':''}</div><span class="chore-name${done?' done-t':''}">${ch.name}</span>`;
